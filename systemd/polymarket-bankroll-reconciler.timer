[Unit]
Description=Run the Polymarket bankroll reconciler every minute
Requires=polymarket-bankroll-reconciler.service

[Timer]
# Fire 30s after boot, then every 60s thereafter. Persistent=true means
# the timer catches up after downtime (the script is idempotent so this
# is safe — duplicate runs simply re-upsert the same row).
OnBootSec=30s
OnUnitActiveSec=60s
AccuracySec=5s
Persistent=true

[Install]
WantedBy=timers.target
