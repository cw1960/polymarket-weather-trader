# Analyzer worker config
# Copy to .env on the bot server and fill in real values.

# Shared token between Netlify Function and this worker. Generate with:
#   openssl rand -hex 32
ANALYZER_AUTH_TOKEN=

# Anthropic API key for commentary generation
ANTHROPIC_API_KEY=

# Supabase — same project as the trading bot
SUPABASE_URL=
SUPABASE_KEY=

# Where strategy_context.md lives. Default works if you run from the analyzer/ dir.
STRATEGY_CONTEXT_FILE=./strategy_context.md

# Bind address — leave on 127.0.0.1; Caddy proxies external traffic to here
HOST=127.0.0.1
PORT=8001

# Cache TTL for /analyze (seconds). Set to 0 to always force fresh.
CACHE_TTL_SECONDS=3600
